{
  "display_information": {
    "name": "Medic Mouse",
    "description": "Medical contraindication checker for aesthetic treatments",
    "background_color": "#FF6B6B"
  },
  "features": {
    "bot_user": {
      "display_name": "Medic Mouse",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "chat:write",
        "chat:write.public"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}